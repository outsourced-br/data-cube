  public static TimeWindowMetricResult<T> PreviousPeriod<T>(
    this AnalyticsCube cube,
    Dimension dimension,
    Hierarchy hierarchy,
    DimensionValue member,
    Metric<T> metric)
    where T : struct
  {
    ArgumentNullException.ThrowIfNull(cube);
