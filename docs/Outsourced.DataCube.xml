namespace Outsourced.DataCube;

using Metrics;

public static class AnalyticsCubeCalculationExtensions
{
  public static T Calculate<T>(this AnalyticsCube cube, Metric<T> metric, Func<IEnumerable<T>, T> aggregation)
    where T : struct
  {
    ArgumentNullException.ThrowIfNull(cube);
    ArgumentNullException.ThrowIfNull(metric);
    ArgumentNullException.ThrowIfNull(aggregation);

    var values = cube.EnumerateValues(metric);

    // Apply the aggregation function to all collected values
    return values.Any() ? aggregation(values) : default;
  }

  public static T Calculate<T>(this AnalyticsCube cube, string metricKey, Func<IEnumerable<T>, T> aggregation)
    where T : struct
  {
    ArgumentNullException.ThrowIfNull(cube);
    ArgumentException.ThrowIfNullOrEmpty(metricKey);
    ArgumentNullException.ThrowIfNull(aggregation);

    var values = cube.EnumerateValues<T>(metricKey);

    // Apply the aggregation function to all collected values
    return values.Any() ? aggregation(values) : default;
  }

  public static T Calculate<T>(this AnalyticsCube cube, Dimension dimension, Metric<T> metric, Func<IEnumerable<T>, T> aggregation)
    where T : struct
  {
    ArgumentNullException.ThrowIfNull(cube);
    ArgumentNullException.ThrowIfNull(dimension);
    ArgumentNullException.ThrowIfNull(metric);
    ArgumentNullException.ThrowIfNull(aggregation);

    var values = cube.EnumerateValues(dimension, metric);

    // Apply the aggregation function to all collected values
    return values.Any() ? aggregation(values) : default;
  }

  private static IEnumerable<T> EnumerateValues<T>(this AnalyticsCube cube, Metric<T> metric) where T : struct
  {
    var metricType = MetricTypeHelper.GetMetricType<T>();
    var factGroups = cube.FactGroups as List<FactGroup> ?? cube.FactGroups.ToList();

    foreach (var factGroup in factGroups)
    {
      if (factGroup.MetricCollections is Collections.MetricTypeDictionary typedDict)
      {
        if (typedDict.TryGetValue(metricType, out var metricCollection) && metricCollection is MetricCollection<T> typedCollection)
        {
          if (typedCollection.TryGetValue(metric.Key, out var value))
            yield return value;
        }
      }
      else if (factGroup.MetricCollections.TryGetValue(metricType, out var metricCollection) && metricCollection is MetricCollection<T> typedCollection)
      {
        if (typedCollection.TryGetValue(metric.Key, out var value))
          yield return value;
      }
    }
  }

  private static IEnumerable<T> EnumerateValues<T>(this AnalyticsCube cube, string metricKey) where T : struct
  {
    var metricType = MetricTypeHelper.GetMetricType<T>();
    var factGroups = cube.FactGroups as List<FactGroup> ?? cube.FactGroups.ToList();

    foreach (var factGroup in factGroups)
    {
      if (factGroup.MetricCollections is Collections.MetricTypeDictionary typedDict)
      {
        if (typedDict.TryGetValue(metricType, out var metricCollection) && metricCollection is MetricCollection<T> typedCollection)
        {
          if (typedCollection.TryGetValue(metricKey, out var value))
            yield return value;
        }
      }
      else if (factGroup.MetricCollections.TryGetValue(metricType, out var metricCollection) && metricCollection is MetricCollection<T> typedCollection)
      {
        if (typedCollection.TryGetValue(metricKey, out var value))
          yield return value;
      }
    }
  }

  private static IEnumerable<T> EnumerateValues<T>(this AnalyticsCube cube, Dimension dimension, Metric<T> metric) where T : struct
  {
    var metricType = MetricTypeHelper.GetMetricType<T>();
    var factGroups = cube.FactGroups as List<FactGroup> ?? cube.FactGroups.ToList();

    foreach (var factGroup in factGroups)
    {
      if (factGroup.DimensionValues is Collections.FlatStringDictionary<DimensionValue> typedDims)
      {
        if (!typedDims.ContainsKey(dimension.Key))
          continue;
      }
      else if (!factGroup.DimensionValues.ContainsKey(dimension.Key))
      {
        continue;
      }

      if (factGroup.MetricCollections is Collections.MetricTypeDictionary typedDict)
      {
        if (typedDict.TryGetValue(metricType, out var metricCollection) && metricCollection is MetricCollection<T> typedCollection)
        {
          if (typedCollection.TryGetValue(metric.Key, out var value))
            yield return value;
        }
      }
      else if (factGroup.MetricCollections.TryGetValue(metricType, out var metricCollection) && metricCollection is MetricCollection<T> typedCollection)
      {
        if (typedCollection.TryGetValue(metric.Key, out var value))
          yield return value;
      }
    }
  }

  #region Common Aggregations

  // Common aggregation functions as convenience methods
  public static int Sum(this AnalyticsCube cube, Metric<int> metric)
  {
    return cube.Calculate(metric, values => values.Sum());
  }

  public static double Sum(this AnalyticsCube cube, Metric<double> metric)
  {
    return cube.Calculate(metric, values => values.Sum());
  }

  public static decimal Sum(this AnalyticsCube cube, Metric<decimal> metric)
  {
    return cube.Calculate(metric, values => values.Sum());
  }

  public static double Average(this AnalyticsCube cube, Metric<int> metric)
  {
    return cube.Calculate(metric, values => (int)(values.Any() ? values.Average() : 0));
  }

  public static double Average(this AnalyticsCube cube, Metric<double> metric)
  {
    return cube.Calculate(metric, values => values.Any() ? values.Average() : 0);
  }

  public static decimal Average(this AnalyticsCube cube, Metric<decimal> metric)
  {
    return cube.Calculate(metric, values => values.Any() ? values.Average() : 0m);
  }

  public static T Min<T>(this AnalyticsCube cube, Metric<T> metric) where T : struct, IComparable<T>
  {
    return cube.Calculate(metric, values => values.Any() ? values.Min() : default);
  }

  public static T Max<T>(this AnalyticsCube cube, Metric<T> metric) where T : struct, IComparable<T>
  {
    return cube.Calculate(metric, values => values.Any() ? values.Max() : default);
  }

  #endregion
}
